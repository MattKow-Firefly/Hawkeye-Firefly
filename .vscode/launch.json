{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Hawkeye: live SITL",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [
          "-n",
          "1",
          "-mc"
      ],
      "stopAtEntry": false,
      // Run from build/ — CMake copies models/shaders/fonts/textures/themes there.
      "cwd": "${workspaceFolder}/build",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "hawkeye: build (Release)",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Hawkeye: multiplayer",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [
          "-n",
          "1",
          "-mc",
          "-mp"
          // Add -name "Pilot" for custom name in multiplayer
          //,"-name", "Pilot"
      ],
      "stopAtEntry": false,
      // -mp: broadcast this drone's position and show LAN peers. Start PX4 SITL
      // first. Peers on the same Wi-Fi are discovered automatically.
      // -name: player name shown in the MP overlay (defaults to login name).
      "cwd": "${workspaceFolder}/build",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "hawkeye: build (Release)",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Hawkeye: replay ULog (pick file)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [
        "--replay",
        "${input:ulogFile}"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/build",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: build hawkeye",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ],
  "inputs": [
    {
      "id": "ulogFile",
      "type": "promptString",
      "description": "Path to a .ulg file to replay"
    }
  ]
}
